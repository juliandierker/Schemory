# Schemory Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# Development Configuration
# =============================================================================

# Development Server
DEV_SERVER_PORT=3000
DEV_DASHBOARD_PORT=5173

# Development Database (Docker Compose)
DEV_DB_HOST=localhost
DEV_DB_PORT=5432
DEV_DB_USER=postgres
DEV_DB_PASSWORD=postgres
DEV_DB_NAME=schemory

# Development Activation URL (for email links in dev)
DEV_ACTIVATION_BASE_URL=http://localhost:5173/auth/activate

# =============================================================================
# Production Configuration
# =============================================================================

# Server
SERVER_PORT=3000
NODE_ENV=production

# Dashboard
DASHBOARD_PORT=80

# Database Configuration
# Option 1: Use DATABASE_URL (single connection string)
DATABASE_URL=postgres://user:password@host:5432/schemory

# Option 2: Use individual variables (takes precedence over DATABASE_URL if all are set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=schemory

# Email Service (Resend)
# Get your API key from https://resend.com
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM_ADDRESS=noreply@schemory.app

# Application URLs
APP_BASE_URL=https://schemory.app
ACTIVATION_BASE_URL=https://api.schemory.app/auth/activate

# =============================================================================
# Test Configuration
# =============================================================================

# Test Database (separate from development database)
TEST_DB_HOST=localhost
TEST_DB_PORT=5433
TEST_DB_USER=postgres
TEST_DB_PASSWORD=postgres
TEST_DB_NAME=schemory_test

# =============================================================================
# Docker Compose Overrides
# =============================================================================

# To use with docker-compose.dev.yml, these are the relevant variables:
# - Server connects to: postgres://postgres:postgres@postgres:5432/schemory
# - Dashboard connects to: http://localhost:3000

# To use with docker-compose.prod.yml, provide:
# - DATABASE_URL or DB_HOST, DB_PORT, DB_USER, DB_PASSWORD, DB_NAME
# - RESEND_API_KEY
# - EMAIL_FROM_ADDRESS
# - ACTIVATION_BASE_URL
