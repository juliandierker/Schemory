# Production environment template (Hetzner VPS ONLY)
# Copy to .env.production on the VPS — never commit real secrets.
#
#   cp .env.production.example .env.production
#
# deploy-prod.sh prefers .env.production; falls back to .env if it looks like prod.

SCHEMORY_ENV=production
NODE_ENV=production

# Postgres — password MUST match the password used when the volume was first created
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=schemory

# Email (Resend)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM_ADDRESS=noreply@schemory.org
ACTIVATION_BASE_URL=https://schemory.org/activate

# Browser-reachable API URL (baked into dashboard image at build time)
# NEVER use http://localhost:3000 or http://server:3000 here
VITE_API_URL=https://api.schemory.org
