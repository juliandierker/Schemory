# Schemory env templates (copy the one you need — never commit real secrets)

# Local development:
#   cp .env.development.example .env.development
#   ./scripts/dev-up.sh

# Production VPS (Hetzner):
#   cp .env.production.example .env.production
#   ./scripts/deploy-prod.sh

# See .env.development.example and .env.production.example for full variable lists.
# Do not mix: a file with SCHEMORY_ENV=production must not be used for local compose.
