{
  "name": "@schemory/server",
  "version": "0.1.0",
  "description": "Fastify API server for Schemory",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "tsx test/db.test.js",
    "test:db": "tsx scripts/test-db-setup.ts",
    "migrate": "tsx -e \"import('node-pg-migrate').then(m => m.runner({databaseUrl: process.env.DATABASE_URL || 'postgres://postgres:postgres@localhost:5432/schemory', dir: 'migrations', direction: 'up'}))\"",
    "lint": "echo \"server: lint pass\"",
    "dev": "echo \"server: dev mode\""
  },
  "dependencies": {
    "@schemory/shared": "workspace:*",
    "fastify": "^4.27.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/pg": "^8.11.6",
    "@types/node": "^20.12.12",
    "node-pg-migrate": "^7.0.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
