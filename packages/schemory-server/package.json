{
  "name": "schemory-server",
  "version": "0.1.0",
  "description": "Schemory Vault Service - Backend API for storing TypeScript types and JSON schemas",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "db:generate": "drizzle-kit generate:pg",
    "db:push": "drizzle-kit push:pg",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "better-sqlite3": "^9.0.0",
    "drizzle-orm": "^0.30.8",
    "fastify": "^4.27.0",
    "fastify-plugin": "^4.5.1",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.24",
    "@types/pg": "^8.11.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitest/coverage-v8": "^1.3.1",
    "drizzle-kit": "^0.20.17",
    "eslint": "^8.57.0",
    "tsx": "^4.7.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "fastify",
    "api",
    "vault",
    "schemas",
    "typescript",
    "drizzle"
  ],
  "author": "",
  "license": "MIT"
}
