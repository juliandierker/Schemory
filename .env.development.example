# Local / development environment template
# Copy to .env.development (or .env.local) — NEVER use this file on the VPS.
#
#   cp .env.development.example .env.development

SCHEMORY_ENV=development
NODE_ENV=development

# Local API / dashboard (host machine or docker-compose.dev.yml)
SCHEMORY_API_URL=http://localhost:3000
VITE_API_URL=http://localhost:3000
ACTIVATION_BASE_URL=http://localhost:5173/activate

# Local Postgres (docker-compose.dev.yml / docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=schemory
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=schemory

# Email: left empty → server logs activation links to console in development
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@localhost

# Test DB (docker-compose.yml postgres-test)
TEST_DB_HOST=localhost
TEST_DB_PORT=5433
TEST_DB_USER=postgres
TEST_DB_PASSWORD=postgres
TEST_DB_NAME=schemory_test
