# Schemory Server Configuration

# Database URL
# For PostgreSQL: postgres://user:password@host:port/database
# For SQLite: file:./data/schemory.db
DATABASE_URL=file:./data/schemory.db

# Server port
PORT=5555

# Node environment
NODE_ENV=development

# API URL for dashboard (when running separately)
VITE_API_URL=http://localhost:5555

# Optional: Rate limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=1000

# Optional: Log level
LOG_LEVEL=info
